---
const repoUrl = 'https://github.com/Dru89/sift'
---

<footer class="footer">
  <div class="container">
    <p>
      Built by <a href="https://github.com/Dru89">Drew Hays</a>.
      Open source on <a href={repoUrl}>GitHub</a>.
      Licensed under MIT.
    </p>
  </div>
</footer>

<style>
  .footer {
    padding: 32px 0;
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 24px;
  }

  .footer p {
    font-size: 13px;
    color: var(--color-text-secondary);
  }

  .footer a {
    color: var(--color-text-secondary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .footer a:hover {
    color: var(--color-text);
  }
</style>
