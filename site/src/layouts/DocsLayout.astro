---
import Layout from './Layout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'

interface Props {
  title: string
  description?: string
  currentPath?: string
}

const { title, description, currentPath } = Astro.props

const navItems = [
  { href: '/getting-started/', label: 'Getting Started' },
  { href: '/cli/', label: 'CLI Reference' },
  { href: '/agents/', label: 'Agent Integration' },
]
---

<Layout title={title} description={description}>
  <Header currentPath={currentPath} />

  <div class="docs-layout">
    <aside class="sidebar">
      <nav class="sidebar-nav">
        <h3>Documentation</h3>
        <ul>
          {navItems.map(item => (
            <li>
              <a href={item.href} class:list={[{ active: currentPath === item.href }]}>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>

    <main class="docs-content">
      <slot />
    </main>
  </div>

  <Footer />
</Layout>

<style>
  .docs-layout {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 48px;
    min-height: calc(100vh - 56px - 96px);
  }

  .sidebar {
    padding-top: 40px;
  }

  .sidebar-nav h3 {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-secondary);
    margin-bottom: 12px;
  }

  .sidebar-nav ul {
    list-style: none;
  }

  .sidebar-nav li {
    margin-bottom: 4px;
  }

  .sidebar-nav a {
    display: block;
    padding: 6px 12px;
    font-size: 14px;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-radius: 6px;
    transition: all 0.15s;
  }

  .sidebar-nav a:hover {
    color: var(--color-text);
    background: var(--color-bg-alt);
  }

  .sidebar-nav a.active {
    color: var(--color-accent);
    background: var(--color-accent-subtle);
    font-weight: 500;
  }

  .docs-content {
    padding: 40px 0 80px;
    min-width: 0;
  }

  /* Docs prose styles */
  .docs-content :global(h1) {
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }

  .docs-content :global(.subtitle) {
    font-size: 16px;
    color: var(--color-text-secondary);
    margin-bottom: 32px;
  }

  .docs-content :global(h2) {
    font-size: 22px;
    font-weight: 600;
    margin-top: 48px;
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--color-border);
  }

  .docs-content :global(h3) {
    font-size: 17px;
    font-weight: 600;
    margin-top: 32px;
    margin-bottom: 12px;
  }

  .docs-content :global(p) {
    margin-bottom: 16px;
    line-height: 1.7;
  }

  .docs-content :global(ul),
  .docs-content :global(ol) {
    margin-bottom: 16px;
    padding-left: 24px;
  }

  .docs-content :global(li) {
    margin-bottom: 6px;
    line-height: 1.6;
  }

  .docs-content :global(pre) {
    margin-bottom: 20px;
  }

  .docs-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 20px;
    font-size: 14px;
  }

  .docs-content :global(th) {
    text-align: left;
    padding: 8px 12px;
    font-weight: 600;
    border-bottom: 2px solid var(--color-border);
  }

  .docs-content :global(td) {
    padding: 8px 12px;
    border-bottom: 1px solid var(--color-border);
  }

  .docs-content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding: 8px 16px;
    margin-bottom: 16px;
    background: var(--color-bg-alt);
    border-radius: 0 6px 6px 0;
    color: var(--color-text-secondary);
  }

  @media (max-width: 768px) {
    .docs-layout {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .sidebar {
      padding-top: 16px;
      padding-bottom: 16px;
      border-bottom: 1px solid var(--color-border);
    }

    .sidebar-nav ul {
      display: flex;
      gap: 4px;
    }

    .sidebar-nav h3 {
      display: none;
    }

    .docs-content {
      padding-top: 24px;
    }
  }
</style>
